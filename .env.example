# ── Required ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
GEMINI_API_KEY=
RESEND_API_KEY=
NEXT_PUBLIC_UNIVERSITY_EMAIL_DOMAIN=@your-university-domain.edu.ng
ADMIN_SECRET_PATH=your-admin-secret-path

# ── Optional ──────────────────────────────────────────────
GEMINI_MODEL=your-gemini-model

# ── Production hardening checklist ────────────────────────
# Supabase: Project Settings → Database → Network Restrictions
#   → Add IP restriction (your deployment IPs only)
#   → Enable connection pooling (Supavisor port 6543)
# Env vars: NEVER commit .env.local. Use platform secrets (Vercel env).
# HTTPS: Verify TLS 1.2+ at the CDN/edge tier.
